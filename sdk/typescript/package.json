{
  "name": "@contextgraphprotocol/typescript-sdk",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript SDK for building conformant Context Graph Protocol providers.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "context-graph-protocol",
    "cgp",
    "context",
    "provider",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18"
  }
}
